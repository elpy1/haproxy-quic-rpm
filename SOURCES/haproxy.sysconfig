# Override systemd haproxy.service environment variables.
# Run "systemctl show -p Environment haproxy" to get default values.
# Run "systemctl show -p ExecStart haproxy" to see how variables are used.
#
# Example overrides:
# CONFIG=/etc/haproxy/haproxy.cfg
# CONFIGDIR=/etc/haproxy/conf.d
# PIDFILE=/run/haproxy.pid
# EXTRAOPTS=-S /run/haproxy-master.sock
